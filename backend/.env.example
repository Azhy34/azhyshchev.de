# Express Server Port
PORT=3000

# CORS Whitelist Origin (For production, set to https://azhyshchev.de)
CORS_ORIGIN=https://azhyshchev.de

# Token required in X-Widget-Token header to authenticate widget requests
SECRET_WIDGET_TOKEN=your_secret_widget_token_here

# Gemini API Key (obtained from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Node Environment (development or production)
NODE_ENV=development
