# Express Server Port
PORT=3000

# Node Environment (development or production)
NODE_ENV=development

# CORS Whitelist Origin (comma-separated, e.g. https://azhyshchev.de,https://www.azhyshchev.de)
CORS_ORIGIN=https://azhyshchev.de

# Token required in X-Widget-Token header to authenticate widget requests
SECRET_WIDGET_TOKEN=your_secret_widget_token_here

# OpenRouter API Key (openrouter.ai → Keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use via OpenRouter (default: google/gemini-2.5-flash)
# Other options: google/gemini-2.5-pro, anthropic/claude-3-5-haiku, openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional — Telegram logging (each chat turn sent to bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — Supabase logging + lead context lookup
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# Optional — disable Gemini cache in dev mode
DISABLE_CACHE=false

# Bing Webmaster Tools API Key (Settings → API Access → Generate API Key)
BING_API_KEY=your_bing_api_key_here
